from django.test import TestCase

# Create your tests here.
from django.contrib.staticfiles.testing import StaticLiveServerTestCase
from selenium.webdriver.firefox.webdriver import WebDriver
from selenium.webdriver.firefox.options import Options
from selenium.webdriver.common.by import By
from django.contrib.auth.models import User
from selenium.common.exceptions import NoSuchElementException

class MySeleniumTests(StaticLiveServerTestCase):

    @classmethod
    def setUpClass(cls):
        super().setUpClass()
        opts = Options()
        # El mode headless és obligatori per a GitHub Actions i servidors sense GUI [cite: 76]
        opts.add_argument("--headless")
        cls.selenium = WebDriver(options=opts)
        cls.selenium.implicitly_wait(5) # Espera fins a 5s per trobar elements [cite: 46]
        
        # Creem el superusuari programàticament com demana l'enunciat [cite: 47-51]
        user = User.objects.create_user("isard", "isard@isardvdi.com", "pirineus")
        user.is_superuser = True
        user.is_staff = True
        user.save()

    @classmethod
    def tearDownClass(cls):
        # Tanquem el navegador en acabar
        cls.selenium.quit()
        super().tearDownClass()

    def test_admin_crear_pregunta(self):
        # 1. Anar al login de l'admin
        self.selenium.get('%s%s' % (self.live_server_url, '/admin/login/'))
        
        # 2. Login (simulant usuari real amb send_keys i click) [cite: 55]
        self.selenium.find_element(By.NAME, "username").send_keys('isard')
        self.selenium.find_element(By.NAME, "password").send_keys('pirineus')
        self.selenium.find_element(By.XPATH, '//input[@type="submit"]').click()
        
        # 3. Navegar fins a "Questions" i clicar "Add"
        # Nota: Fem servir LINK_TEXT per trobar l'enllaç com un usuari
        self.selenium.find_element(By.LINK_TEXT, "Questions").click()
        self.selenium.find_element(By.XPATH, "//a[contains(@class, 'addlink')]").click()
        
        # 4. Omplir el formulari de la pregunta
        input_text = self.selenium.find_element(By.NAME, "question_text")
        input_text.send_keys("Pregunta creada per Selenium")
        
        # Fem clic als enllaços "Today" i "Now" que genera Django
        self.selenium.find_element(By.LINK_TEXT, "Today").click()
        self.selenium.find_element(By.LINK_TEXT, "Now").click()
        
        # 5. Guardar [cite: 55]
        self.selenium.find_element(By.NAME, "_save").click()
        
        # 6. Comprovar que s'ha creat correctament (Assert) [cite: 56]
        # Busquem el missatge d'èxit típic de l'admin de Django
        success_message = self.selenium.find_element(By.CLASS_NAME, "success")
        self.assertIn("was added successfully", success_message.text)
